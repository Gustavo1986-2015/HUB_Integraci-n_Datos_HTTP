# =============================================================================
# Hub de Integración Satelital — Plantilla de Configuración (.env.example)
# =============================================================================
# INSTRUCCIONES:
#   1. Copiar este archivo:  cp .env.example .env
#   2. Completar los valores marcados con <completar>
#   3. Nunca subir el .env real al repositorio (está en .gitignore)
#
# Para producción (Railway): cargar cada variable en el panel Variables.
# =============================================================================


# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
LOG_RETENTION_HOURS=48
COLA_MAX_HORAS=24


# ── Modo prueba ───────────────────────────────────────────────────────────────
# true  → sin envíos reales (para pruebas)
# false → operación normal
DRY_RUN=false


# ── Seguridad — Ingesta ───────────────────────────────────────────────────────
# Token que los prestadores deben incluir al enviarnos datos.
# Dejar vacío para deshabilitar (solo desarrollo local).
HUB_INGEST_TOKEN=


# ── Seguridad — UI de Configuración ──────────────────────────────────────────
# Protege el panel /configuracion con usuario y contraseña.
# Dejar vacíos en local. OBLIGATORIO en producción.
CONFIG_USUARIO=admin
CONFIG_CLAVE=<completar>


# =============================================================================
# DESTINOS — A donde enviamos los datos normalizados
# =============================================================================

# ── Recurso Confiable (SOAP/XML) ──────────────────────────────────────────────
# IMPORTANTE: Usar http:// (no https://)
SEND_TO_RECURSO_CONFIABLE=false
RC_SOAP_URL=http://gps.rcontrol.com.mx/Tracking/wcf/RCService.svc
RC_USER_ID=<completar>
RC_PASSWORD=<completar>

# ── Simon 4.0 (REST/JSON) ─────────────────────────────────────────────────────
# SIMON_BASE_URL: URL completa del endpoint de recepción.
# SIMON_API_TOKEN: Token Bearer fijo. Dejar vacío si no aplica.
# SIMON_USER_AVL: Identificador del operador AVL dentro de Simon.
# SIMON_SOURCE_TAG: Etiqueta de origen opcional. Dejar vacío si no aplica.
SEND_TO_SIMON=false
SIMON_BASE_URL=<completar>
SIMON_API_TOKEN=
SIMON_USER_AVL=
SIMON_SOURCE_TAG=

# ── Zona horaria ──────────────────────────────────────────────────────────────
TIMEZONE_OFFSET=-05:00


# =============================================================================
# APIS — Prestadores cuya API consultamos nosotros
# =============================================================================

# ── Control Group ─────────────────────────────────────────────────────────────
CONTROL_GROUP_ENABLED=false
CONTROL_GROUP_URL=https://gateway.control-group.com.ar/gateway.asp
CONTROL_GROUP_USER=<completar>
CONTROL_GROUP_PASS=<completar>
CONTROL_GROUP_INTERVAL=60


# =============================================================================
# ROUTING — A qué destino van los datos de cada proveedor
# =============================================================================
# Valores: recurso_confiable | simon | recurso_confiable,simon
# ─────────────────────────────────────────────────────────────────────────────
# DESTINOS_CONTROL_GROUP=recurso_confiable
# DESTINOS_DEFAULT=recurso_confiable
