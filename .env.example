# =============================================================================
# Hub de Integración Satelital — Variables de Entorno
# =============================================================================
# Copiar como .env:  cp .env.example .env
# Completar valores marcados con <completar>
# NUNCA subir el .env al repositorio
# =============================================================================


# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8000
# Nivel de detalle de logs: DEBUG | INFO | WARNING | ERROR
# DEBUG muestra detalles de red (útil para depuración, ruidoso en producción)
# INFO es el nivel recomendado para operación normal
LOG_LEVEL=INFO
# Horas que se conservan los archivos de log en disco antes de eliminarse
LOG_RETENTION_HOURS=48


# ── Modo prueba ───────────────────────────────────────────────────────────────
# true  = normaliza y loguea, pero NO envía datos a RC ni Simon
# false = operación normal con envíos reales
DRY_RUN=false


# ── Seguridad — Ingesta ───────────────────────────────────────────────────────
# Token que los prestadores deben incluir al enviarnos datos
# Header: Authorization: Bearer <token>
# Dejar vacío para deshabilitar (solo desarrollo local)
HUB_INGEST_TOKEN=


# ── Seguridad — UI de Configuración ──────────────────────────────────────────
# Usuario y contraseña para acceder a /configuracion desde el navegador
# El navegador mostrará un diálogo de login automáticamente
# Dejar vacíos en local. En producción SIEMPRE configurar estos valores.
CONFIG_USUARIO=admin
CONFIG_CLAVE=<completar>


# =============================================================================
# DESTINOS — A donde enviamos los datos
# =============================================================================

# ── Recurso Confiable (SOAP/XML) ──────────────────────────────────────────────
SEND_TO_RECURSO_CONFIABLE=false
RC_SOAP_URL=http://gps.rcontrol.com.mx/Tracking/wcf/RCService.svc
RC_USER_ID=<completar>
RC_PASSWORD=<completar>

# ── Simon 4.0 (REST/JSON) ─────────────────────────────────────────────────────
SEND_TO_SIMON=false
SIMON_BASE_URL=<completar>
SIMON_API_TOKEN=<completar>
SIMON_USER_AVL=Rusertech
SIMON_SOURCE_TAG=


# ── Zona horaria para normalización de fechas ─────────────────────────────────
TIMEZONE_OFFSET=-05:00


# =============================================================================
# APIS — De donde obtenemos los datos (ingestores activos)
# =============================================================================

# ── Control Group ─────────────────────────────────────────────────────────────
CONTROL_GROUP_ENABLED=true
CONTROL_GROUP_URL=https://gateway.control-group.com.ar/gateway.asp
CONTROL_GROUP_USER=<completar>
CONTROL_GROUP_PASS=<completar>
CONTROL_GROUP_INTERVAL=60


# =============================================================================
# ROUTING — Qué API envía a qué destino
# =============================================================================
# Valores: recurso_confiable | simon | recurso_confiable,simon
# ─────────────────────────────────────────────────────────────────────────────
DESTINOS_CONTROL_GROUP=simon
# DESTINOS_DEFAULT=recurso_confiable
