# =============================================================================
# Hub de Integración Satelital — Variables de Entorno
# =============================================================================
# Para desarrollo local: copiar este archivo como .env
#   cp .env.example .env
# Luego editar .env con tus valores reales.
#
# En Railway: cargar estas variables en el panel "Variables" del proyecto.
# NUNCA subir el archivo .env al repositorio.
# =============================================================================


# ── Servidor ──────────────────────────────────────────────────────────────────
# Railway inyecta PORT automáticamente. Solo es necesario para local.
PORT=8000

# Nivel de detalle de los logs: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Modo prueba local ─────────────────────────────────────────────────────────
# true  → normaliza y loguea, pero NO envía datos a RC ni Simon
# false → operación normal
DRY_RUN=false


# ── Seguridad ─────────────────────────────────────────────────────────────────
# Token que los prestadores deben incluir al enviarnos datos.
# Formato del header: Authorization: Bearer <token>
# Dejar vacío para deshabilitar la validación (solo desarrollo local).
HUB_INGEST_TOKEN=


# =============================================================================
# ROUTING POR PROVEEDOR
# =============================================================================
# Define a qué destino(s) van los datos de cada proveedor.
# Formato:  DESTINOS_{NOMBRE_PROVEEDOR}=destino1,destino2
# Valores:  recurso_confiable | simon | recurso_confiable,simon
#
# Prioridad de resolución:
#   1. DESTINOS_{PROVEEDOR}  → específico para ese proveedor
#   2. DESTINOS_DEFAULT      → fallback para todos los que no tienen específico
#   3. Flags ENVIAR_A_* más abajo → modo básico si no hay DESTINOS_*
#
# Ejemplos:
#   DESTINOS_CONTROL_GROUP=simon
#   DESTINOS_MI_PROVEEDOR=recurso_confiable
#   DESTINOS_OTRO=recurso_confiable,simon
#   DESTINOS_DEFAULT=recurso_confiable,simon
# =============================================================================
# DESTINOS_CONTROL_GROUP=simon
# DESTINOS_DEFAULT=recurso_confiable,simon


# ── Destino A: Recurso Confiable (SOAP/XML) ───────────────────────────────────
# Se usa si no existe DESTINOS_{PROVEEDOR} ni DESTINOS_DEFAULT
SEND_TO_RECURSO_CONFIABLE=false
RC_SOAP_URL=https://gps.rcontrol.com.mx/Tracking/wcf/RCService.svc
RC_USER_ID=tu_usuario_rc
RC_PASSWORD=tu_clave_rc


# ── Destino B: Simon 4.0 (REST/JSON) ─────────────────────────────────────────
SEND_TO_SIMON=false
SIMON_BASE_URL=https://tu-hubreceptor-simon.com
SIMON_USER_AVL=avl
SIMON_SOURCE_TAG=
# Token Bearer fijo que Simon entrega una sola vez (no expira, no hay login)
SIMON_API_TOKEN=


# ── Zona horaria para normalización de fechas ─────────────────────────────────
# Se agrega a las fechas al normalizarlas.
# Ejemplos: -05:00 (México Centro), -03:00 (Argentina)
# Nota: Control Group usa -03:00 internamente (hardcodeado en su ingestor)
TIMEZONE_OFFSET=-00:00


# =============================================================================
# INGESTORES ACTIVOS
# (Prestadores cuya API consultamos nosotros — no nos envían datos)
# =============================================================================

# ── Control Group Gateway ─────────────────────────────────────────────────────
# Protocolo: XML sobre HTTP (NO SOAP). Revisión: 26/01/2024
CONTROL_GROUP_ENABLED=false
CONTROL_GROUP_URL=https://gateway.control-group.com.ar/gateway.asp
CONTROL_GROUP_USER=assist
CONTROL_GROUP_PASS=cargo
# Segundos entre cada consulta al gateway (mínimo recomendado: 60)
CONTROL_GROUP_INTERVAL=60
# Destino para Control Group (ejemplos):
# DESTINOS_CONTROL_GROUP=simon
DESTINOS_CONTROL_GROUP=recurso_confiable
# DESTINOS_CONTROL_GROUP=recurso_confiable,simon
